# =============================================================================
# Pipeline Configuration
# Copy this file to config.env and customize for your project
# =============================================================================

# --- AI Models ---
MODEL=opus                             # Model for planner/coder/tester agents
REVIEW_MODEL=opus                      # Model for reviewer (deeper analysis)
REPORT_MODEL=opus                      # Model for report/QA generators

# --- Retry ---
MAX_RETRIES=2                          # Max retry attempts per agent call
RETRY_DELAY=3                          # Seconds between retries

# --- Iteration ---
MAX_FIX_ITERATIONS=3                   # Max fix->retest->review cycles (direct strategy)
MAX_ITERATIONS=5                       # Max full plan->code->test->review iterations (replan strategy)

# --- Feedback Strategy ---
# "direct"  — reviewer REQUEST_CHANGES → coder fixes → retest → re-review
# "replan"  — any failure → feedback to planner → full replanning
FEEDBACK_STRATEGY=replan

# --- Logging ---
LOG_LEVEL=info                         # debug, info, warn, error

# --- Git ---
AUTO_GIT=false                         # Enable git prepare/commit stages
AUTO_COMMIT=false                      # Auto-commit on APPROVE
BRANCH_PREFIX=pipeline                 # Branch name prefix
BRANCH_PATTERN="${BRANCH_PREFIX}_${TASK_ID}" # Branch naming pattern

# --- Project / Language ---
PROJECT_NAME="my-project"              # Project name for context
LANGUAGE=go                            # Primary language (go, python, typescript, rust, java...)
PROJECT_ROOT=""                        # Absolute path to project repo (auto-detected if empty)
PROJECT_CONTEXT=""                     # Path to project CLAUDE.md or context file (optional)

# --- Build & Verify Commands ---
BUILD_CMD="go build ./..."             # Build command
TEST_CMD="go test ./... -count=1 -timeout 5m"  # Unit test command
LINT_CMD="golangci-lint run"           # Linter command (empty to skip)
VET_CMD="go vet ./..."                 # Static analysis command (empty to skip)
VERIFY_CMDS="${VET_CMD} && ${BUILD_CMD} && ${TEST_CMD}"  # Full verify chain for coder

# --- E2E Testing ---
E2E_ENABLED=false                      # Enable E2E testing stage
E2E_BASE_URL=http://localhost:8000     # Base URL for E2E tests
SERVER_START_CMD=""                    # Command to start server (empty = skip)
SERVER_STOP_CMD=""                     # Command to stop server
SERVER_HEALTH_URL=""                   # Health check endpoint (e.g., /health)
SERVER_STARTUP_TIMEOUT=60              # Max seconds to wait for server to be healthy

# --- Post-processing ---
QA_ENABLED=true                        # Generate QA test cases after APPROVE
REPORT_ENABLED=true                    # Generate final report after APPROVE
REPORT_LANGUAGE=ru                     # Report language (ru, en, etc.)

# --- Retrospective (Self-Improvement) ---
RETRO_ENABLED=true                     # Run retrospective analysis after multi-iteration runs

# --- Misc ---
DRY_RUN=false                          # Show pipeline flow without calling claude
